<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  
  # ═══════════════════════════════════════════════════════════════════════════
  # PRESERVE AUTHORIZATION HEADER (for JWT Bearer tokens)
  # Apache strips Authorization headers by default - this preserves them
  # ═══════════════════════════════════════════════════════════════════════════
  RewriteCond %{HTTP:Authorization} ^(.*)
  RewriteRule .* - [e=HTTP_AUTHORIZATION:%1]
  
  # Forward API requests directly to api.php
  # This ensures they don't get caught by the SPA catch-all
  RewriteRule ^api\.php$ - [L]

  # SPA Routing: Route non-existent files through seo_router.php to inject dynamic SEO tags
  RewriteRule ^seo_router\.php$ - [L]
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-e
  RewriteRule . /seo_router.php [L]
</IfModule>
